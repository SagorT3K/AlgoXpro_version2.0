# Quotex credentials (required)
QUOTEX_EMAIL=your@email.com
QUOTEX_PASSWORD=your_password

# Account mode
QUOTEX_DEMO=true

# Multiple accounts for connection pooling (optional)
# Format: JSON array of {email, password, is_demo, label}
QUOTEX_ACCOUNTS=[]

# Redis URL (for multi-worker mode)
REDIS_URL=redis://localhost:6379
REDIS_MAX_CONNECTIONS=50

# Analyzer thread pool workers
ANALYZER_WORKERS=8

# Worker identifier (auto-assigned in docker-compose)
WORKER_ID=0
